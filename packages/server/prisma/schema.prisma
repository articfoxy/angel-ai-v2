generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Core Models
// ============================================

model User {
  id             String    @id @default(uuid())
  email          String?   @unique
  passwordHash   String?
  name           String?
  provider       String    @default("email")
  providerUserId String?
  apiKeys        Json?     // encrypted BYOK keys
  plan           String    @default("free") // free | pro
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions    Session[]
  episodes    Episode[]
  memories    Memory[]
  entities    Entity[]
  reflections Reflection[]
  coreMemory  CoreMemory?
  skills      Skill[]
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  summary   Json?
  speakers  Json?     // { "speaker_0": "Owner", "speaker_1": "Sarah" }
  skills    String[]  // active skill IDs during session
  status    String    @default("active") // active | ended | processing

  user     User      @relation(fields: [userId], references: [id])
  episodes Episode[]

  @@index([userId])
}

// ============================================
// Layer 1: Episodes (raw transcript segments)
// ============================================

model Episode {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  speaker   String   // "owner", "speaker_1", etc.
  content   String
  startTime DateTime
  endTime   DateTime

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
}

// ============================================
// Layer 2: Memories (extracted facts)
// ============================================

model Memory {
  id          String    @id @default(uuid())
  userId      String
  content     String
  embedding   Unsupported("vector(1536)")?
  importance  Int       @default(5) // 1-10
  accessCount Int       @default(0)
  lastAccessed DateTime?
  validFrom   DateTime  @default(now())
  validTo     DateTime? // null = still valid
  source      String?   // session ID or "manual"
  category    String?   // fact, preference, opinion, event
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// Layer 3: Entities (people, places, topics)
// ============================================

model Entity {
  id        String   @id @default(uuid())
  userId    String
  name      String
  type      String   // person, place, org, topic
  aliases   String[] // ["Sarah", "Sarah Chen", "Dr. Chen"]
  metadata  Json?    // freeform attributes
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  relationsFrom Relationship[] @relation("from")
  relationsTo   Relationship[] @relation("to")

  @@index([userId])
  @@index([userId, type])
}

// ============================================
// Layer 4: Relationships (temporal graph edges)
// ============================================

model Relationship {
  id        String    @id @default(uuid())
  fromId    String
  toId      String
  type      String    // works_with, discussed, friend_of, etc.
  weight    Float     @default(1.0)
  validFrom DateTime  @default(now())
  validTo   DateTime? // null = still valid
  source    String?   // session ID

  from Entity @relation("from", fields: [fromId], references: [id])
  to   Entity @relation("to", fields: [toId], references: [id])

  @@index([fromId])
  @@index([toId])
}

// ============================================
// Layer 5: Reflections (higher-order insights)
// ============================================

model Reflection {
  id             String   @id @default(uuid())
  userId         String
  content        String
  embedding      Unsupported("vector(1536)")?
  importance     Int      @default(7)
  sourceMemories String[] // memory IDs that triggered this
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// Layer 6: Core Memory (self-editing user profile)
// ============================================

model CoreMemory {
  id          String   @id @default(uuid())
  userId      String   @unique
  userProfile String   @default("")
  preferences String   @default("")
  keyPeople   String   @default("")
  activeGoals String   @default("")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ============================================
// Skills
// ============================================

model Skill {
  id           String  @id @default(uuid())
  userId       String
  name         String
  trigger      String?
  systemPrompt String
  outputSchema Json?
  visibility   String  @default("private") // private | public
  downloads    Int     @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([visibility])
}

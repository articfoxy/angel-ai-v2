{
  "expo": {
    "name": "Angel AI",
    "slug": "angel-ai-v2",
    "version": "2.1.0",
    "runtimeVersion": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "angelai",
    "owner": "articfoxy",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.angelai.app",
      "buildNumber": "35",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Angel AI needs microphone access to provide real-time conversation intelligence.",
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSBluetoothAlwaysUsageDescription": "Angel AI uses Bluetooth to connect to your AirPods for hands-free conversation intelligence.",
        "NSBluetoothPeripheralUsageDescription": "Angel AI uses Bluetooth to connect to your AirPods for hands-free conversation intelligence.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0C0A"
    },
    "updates": {
      "url": "https://u.expo.dev/e09202a5-3fdc-4ee6-a646-485b4e99e1c5"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Angel AI needs microphone access to provide real-time conversation intelligence."
        }
      ],
      "expo-apple-authentication",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D97757",
          "defaultChannel": "default"
        }
      ],
      [
        "@siteed/audio-studio",
        {
          "microphonePermission": "Angel AI needs microphone access to provide real-time conversation intelligence."
        }
      ],
      "react-native-audio-api"
    ],
    "extra": {
      "eas": {
        "projectId": "e09202a5-3fdc-4ee6-a646-485b4e99e1c5"
      }
    }
  }
}
